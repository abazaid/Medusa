{
  "name": "my-ecommerce-store",
  "version": "0.0.1",
  "description": "A starter for Medusa projects.",
  "author": "Medusa (https://medusajs.com)",
  "license": "MIT",
  "keywords": [
    "sqlite",
    "postgres",
    "typescript",
    "ecommerce",
    "headless",
    "medusa"
  ],
  "scripts": {
    "build": "node ./node_modules/@medusajs/cli/cli.js build",
    "db:generate:blog": "node ./node_modules/@medusajs/cli/cli.js db:generate blog",
    "db:migrate": "node ./node_modules/@medusajs/cli/cli.js db:migrate",
    "create:vape-categories": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/create-vape-categories.ts",
    "import:products-append": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/import-products-append.ts",
    "import:sample-products": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/import-sample-products.ts",
    "report:product-seo": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/report-product-seo.ts",
    "refresh:product-seo": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/refresh-product-seo.ts",
    "generate:product-descriptions": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/generate-all-product-descriptions.ts",
    "normalize:slugs": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/normalize-store-slugs.ts",
    "classify:product-highlights": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/classify-product-highlights.ts",
    "rewrite:product-links": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/rewrite-product-description-links.ts",
    "repair:inventory-levels": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/repair-inventory-levels.ts",
    "email:test": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/send-test-email.ts",
    "search:sync": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/sync-meilisearch.ts",
    "sync:categories": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/create-vape-categories.ts",
    "seed": "node ./node_modules/@medusajs/cli/cli.js exec ./src/scripts/seed.ts",
    "start": "node ./node_modules/@medusajs/cli/cli.js start",
    "start:production": "node ./scripts/start-production.js",
    "dev": "node ./node_modules/@medusajs/cli/cli.js develop",
    "test:integration:http": "TEST_TYPE=integration:http NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:integration:modules": "TEST_TYPE=integration:modules NODE_OPTIONS=--experimental-vm-modules jest --silent=false --runInBand --forceExit",
    "test:unit": "TEST_TYPE=unit NODE_OPTIONS=--experimental-vm-modules jest --silent --runInBand --forceExit"
  },
  "dependencies": {
    "@alpha-solutions/medusa-image-alt": "^1.1.0",
    "@lambdacurry/medusa-product-reviews": "^1.3.1",
    "@medusajs/admin-sdk": "2.13.1",
    "@medusajs/auth": "2.13.1",
    "@medusajs/cli": "2.13.1",
    "@medusajs/framework": "2.13.1",
    "@medusajs/medusa": "2.13.1",
    "@rokmohar/medusa-plugin-meilisearch": "^1.3.6",
    "dotenv": "^17.3.1",
    "make-error": "^1.3.6",
    "nodemailer": "^8.0.2",
    "run-parallel": "^1.2.0"
  },
  "devDependencies": {
    "@medusajs/test-utils": "2.13.1",
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "bcryptjs": "^3.0.3",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.1.0"
}
